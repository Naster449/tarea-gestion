# === PRODUCCIÓN (Render.com) ===
PORT=10000
NODE_ENV=production
JWT_SECRET=cambia-este-secreto-minimo-32-caracteres-produccion
DATABASE_PATH=/var/data/empresa.db
# CORS_ORIGIN: URL de tu frontend en GitHub Pages
CORS_ORIGIN=https://matluc318-l.github.io/planilla-tarea/
UPLOAD_DIR=/var/data/uploads

# === DESARROLLO LOCAL ===
# Descomenta para desarrollo local:
# PORT=4000
# DATABASE_PATH=./data/empresa.db
# CORS_ORIGIN=http://localhost:5173
# UPLOAD_DIR=./uploads

# Entrada laboral esperada (HH:mm, zona local del servidor)
ATTENDANCE_EXPECTED_TIME=09:00

# Tardanza: minutos de gracia después de la hora esperada
ATTENDANCE_GRACE_MINUTES=5

# Nodemailer (opcional). Si falta SMTP, los correos solo se registran en consola.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="RRHH <no-reply@empresa.local>"
